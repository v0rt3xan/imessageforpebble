{
  "name": "Messages",
  "author": "sebastian o",
  "version": "1.0.0",
  "description": "pMessages is a voice-to-text relay, that also sends iMessages, you need a Outlook account, a iPhone, a Pebble watch with a microphone, and Apple Shortcuts",
  "homepage": "https://",
  "repository": {
    "type": "git",
    "url": "https://github.com/mattnovelli/.git"
  },
  "bugs": {
    "url": "https://github.com/mattnovelli/patch/issues"
  },
  "keywords": [
    "patch",
    "imessage",
    "sms",
    "texting",
    "reply",
    "ios",
    "voice-messaging"
  ],
  "private": true,
  "dependencies": {
    "pebble-clay": "^1.0.4"
  },
  "pebble": {
    "displayName": "Messages",
    "uuid": "b6b5f1c9-2a6b-4b35-bc5b-7b2e6fb6f5cc",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "basalt",
      "chalk",
      "emery"
    ],
    "watchapp": {
      "watchface": false
    },
    "capabilities": [
      "configurable"
    ],
    "messageKeys": [
      "KEY_CONTACT_INDEX",
      "KEY_VOICE_TEXT",
      "KEY_ERROR",
      "KEY_STATUS",
      "KEY_CONTACT_NAMES",
      "KEY_QUIT_AFTER_SEND",
      "KEY_AUTH_STATE",
      "KEY_CANNED_LABELS",
      "KEY_CANNED_INDEX"
    ],
    "resources": {
      "media": [
        {
          "type": "raw",
          "name": "SENT_SEQUENCE",
          "file": "Pebble_80x80_Sent.pdc"
        },
        {
          "type": "png",
          "name": "MENU_ICON",
          "file": "25x25.png",
          "menuIcon": true
        },
        {
          "type": "png",
          "name": "50",
          "file": "50x50.png"
        },
        {
          "type": "png",
          "name": "80",
          "file": "80x80.png"
        }
      ]
    }
  }
}
